{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "StackExchange.Redis": "Information",
      "RedisBlocklistMiddlewareApp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "RedisConnection": "localhost:6379"
  },
  "DefenseEngine": {
    "Redis": {
      "ConnectionString": "localhost:6379",
      "AllowLoopbackConnectionStringInProduction": false,
      "BlocklistKeyPrefix": "blocklist:ip:",
      "FrequencyKeyPrefix": "frequency:ip:",
      "BlocklistDatabase": 2,
      "FrequencyDatabase": 3,
      "BlockDurationMinutes": 240,
      "FrequencyWindowSeconds": 60
    },
    "Heuristics": {
      "KnownBadUserAgents": [
        "GPTBot",
        "CCBot",
        "ClaudeBot",
        "Bytespider",
        "PetalBot",
        "AhrefsBot",
        "SemrushBot",
        "MJ12bot",
        "DotBot",
        "Scrapy",
        "python-requests",
        "curl",
        "wget",
        "masscan",
        "zgrab",
        "nmap",
        "sqlmap",
        "nikto"
      ],
      "SuspiciousPathSubstrings": [
        "/wp-admin",
        "/wp-login",
        "/xmlrpc.php",
        "/.env",
        "/phpmyadmin",
        "/graphql",
        "/admin",
        "/actuator"
      ],
      "CheckEmptyUserAgent": true,
      "CheckMissingAcceptLanguage": true,
      "CheckGenericAcceptHeader": true,
      "TarpitSuspiciousRequests": true,
      "BlockScoreThreshold": 60,
      "FrequencyBlockThreshold": 8
    },
    "Networking": {
      "ClientIpResolutionMode": "Direct",
      "TrustedProxies": []
    },
    "Management": {
      "ApiKeyHeaderName": "X-API-Key",
      "ApiKey": ""
    },
    "Intake": {
      "ApiKeyHeaderName": "X-Webhook-Key",
      "ApiKey": ""
    },
    "Audit": {
      "DatabasePath": "data/defense-events.db",
      "MaxRecentEvents": 500
    },
    "Escalation": {
      "ConfiguredRanges": {
        "Enabled": false,
        "Entries": []
      },
      "HttpReputation": {
        "Enabled": false,
        "Endpoint": "",
        "ApiKeyHeaderName": "X-Api-Key",
        "ApiKey": "",
        "TimeoutSeconds": 10,
        "MaliciousScoreAdjustment": 35
      },
      "OpenAiCompatibleModel": {
        "Enabled": false,
        "Endpoint": "",
        "ApiKey": "",
        "Model": "",
        "SystemPrompt": "You are classifying incoming web requests for scraping-defense enforcement. Return JSON with classification and summary. Classification must be one of MALICIOUS_BOT, BENIGN_CRAWLER, HUMAN, or INCONCLUSIVE.",
        "TimeoutSeconds": 20,
        "MaliciousScoreAdjustment": 40,
        "BenignCrawlerScoreAdjustment": -5,
        "HumanScoreAdjustment": -15
      }
    },
    "CommunityBlocklist": {
      "Enabled": false,
      "SyncIntervalMinutes": 60,
      "RequestTimeoutSeconds": 10,
      "MaximumEntriesPerSource": 5000,
      "Sources": []
    },
    "PeerSync": {
      "Enabled": false,
      "SyncIntervalMinutes": 60,
      "RequestTimeoutSeconds": 10,
      "MaximumSignalsPerPeer": 500,
      "MaximumExportSignals": 500,
      "ExportApiKeyHeaderName": "X-Peer-Key",
      "ExportApiKey": "",
      "Peers": []
    },
    "Queue": {
      "Capacity": 1024
    },
    "Tarpit": {
      "PathPrefix": "/anti-scrape-tarpit",
      "Seed": "ai-scraping-defense-dotnet",
      "LinkCount": 6,
      "ParagraphCount": 5,
      "ResponseDelayMilliseconds": 200,
      "Modes": [
        "Standard",
        "ArchiveIndex",
        "ApiCatalog"
      ],
      "MarkovWordsPerParagraph": 36,
      "PostgresMarkov": {
        "Enabled": false,
        "ConnectionString": "",
        "WordsTableName": "markov_words",
        "SequencesTableName": "markov_sequences",
        "RefreshMinutes": 30
      }
    }
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RedisBlocklistMiddlewareApp": "Information"
    }
  },
  "AllowedHosts": "*",
  "DefenseEngine": {
    "EngineEndpoint": "http://localhost:5000",
    "ApiKey": "",
    "BearerToken": "",
    "TimeoutSeconds": 10,
    "RetryPolicy": {
      "MaxAttempts": 3,
      "BaseDelayMilliseconds": 250
    },
    "ApiRoutes": {
      "HealthPath": "/health",
      "TelemetryPath": "/api/v1/telemetry",
      "PoliciesPath": "/api/v1/policies",
      "EscalationAckPath": "/api/v1/escalations/ack"
    },
    "Sync": {
      "SyncIntervalSeconds": 30
    }
  }
}
